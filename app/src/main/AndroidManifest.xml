<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">
    <uses-sdk
        tools:overrideLibrary="com.xzakota.hyper.notification.focus" />

    <uses-permission
        android:name="android.permission.QUERY_ALL_PACKAGES"
        tools:ignore="PackageVisibilityPolicy,QueryAllPackagesPermission" />
    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission
        android:name="android.permission.NEARBY_WIFI_DEVICES"
        android:maxSdkVersion="36"
        android:usesPermissionFlags="neverForLocation" />
    <uses-permission android:name="android.permission.ACCESS_LOCAL_NETWORK" />
    <uses-permission android:name="android.permission.USE_LOOPBACK_INTERFACE" />
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.POST_PROMOTED_NOTIFICATIONS" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <queries>
        <intent>
            <action android:name="android.intent.action.MAIN" />
            <category android:name="android.intent.category.LAUNCHER" />
        </intent>
    </queries>

    <application
        android:name=".KeiOSApp"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher_android"
        android:roundIcon="@mipmap/ic_launcher_round_android"
        android:label="@string/app_name"
        android:localeConfig="@xml/locales_config"
        android:enableOnBackInvokedCallback="true"
        android:supportsRtl="true"
        android:theme="@style/Theme.KeiOS">

        <provider
            android:name="rikka.shizuku.ShizukuProvider"
            android:authorities="${applicationId}.shizuku"
            android:enabled="true"
            android:exported="true"
            android:multiprocess="false"
            android:permission="android.permission.INTERACT_ACROSS_USERS_FULL" />

        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>

        <activity
            android:name=".MainActivity"
            android:configChanges="keyboardHidden|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
            android:enableOnBackInvokedCallback="true"
            android:launchMode="singleTop"
            android:screenOrientation="sensorPortrait"
            android:windowSoftInputMode="adjustResize"
            android:exported="true" />

        <activity-alias
            android:name=".LauncherAppleDesigns"
            android:enabled="false"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_apple"
            android:label="@string/app_name"
            android:roundIcon="@mipmap/ic_launcher_round_apple"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity-alias
            android:name=".LauncherAndroidDesigns"
            android:enabled="true"
            android:exported="true"
            android:icon="@mipmap/ic_launcher_android"
            android:label="@string/app_name"
            android:roundIcon="@mipmap/ic_launcher_round_android"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity-alias>

        <activity
            android:name=".core.shortcut.AppShortcutActionActivity"
            android:excludeFromRecents="true"
            android:exported="false"
            android:noHistory="true"
            android:taskAffinity=""
            android:theme="@style/Theme.KeiOS.ShortcutAction" />

        <activity
            android:name=".ui.page.main.github.share.GitHubShareImportActivity"
            android:configChanges="keyboardHidden|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
            android:excludeFromRecents="true"
            android:exported="true"
            android:label="@string/github_share_import_activity_title"
            android:launchMode="singleInstance"
            android:theme="@style/Theme.KeiOS.ShareImportWindow">
            <intent-filter>
                <action android:name="android.intent.action.SEND" />

                <category android:name="android.intent.category.DEFAULT" />

                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.page.main.jsonimport.KeiOSJsonImportActivity"
            android:configChanges="keyboardHidden|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
            android:enableOnBackInvokedCallback="true"
            android:exported="true"
            android:label="@string/json_import_title">
            <intent-filter>
                <action android:name="android.intent.action.VIEW" />

                <category android:name="android.intent.category.DEFAULT" />
                <category android:name="android.intent.category.BROWSABLE" />

                <data android:mimeType="application/json" />
                <data android:mimeType="text/json" />
                <data android:mimeType="text/plain" />
            </intent-filter>
            <intent-filter>
                <action android:name="android.intent.action.SEND" />

                <category android:name="android.intent.category.DEFAULT" />

                <data android:mimeType="application/json" />
                <data android:mimeType="text/json" />
                <data android:mimeType="text/plain" />
            </intent-filter>
        </activity>

        <activity
            android:name=".ui.page.main.github.importer.GitHubStarImportActivity"
            android:configChanges="keyboardHidden|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
            android:enableOnBackInvokedCallback="true"
            android:exported="false"
            android:label="@string/github_star_import_title" />

        <activity
            android:name=".ui.page.main.os.shell.OsShellRunnerActivity"
            android:configChanges="keyboardHidden|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
            android:enableOnBackInvokedCallback="true"
            android:exported="false" />

        <activity
            android:name=".ui.page.main.feedback.FeedbackIssueActivity"
            android:configChanges="keyboardHidden|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
            android:enableOnBackInvokedCallback="true"
            android:exported="false"
            android:label="@string/feedback_issue_title" />

        <activity
            android:name=".ui.page.main.ba.BaActivityCalendarActivity"
            android:configChanges="keyboardHidden|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
            android:enableOnBackInvokedCallback="true"
            android:exported="false"
            android:label="@string/ba_calendar_activity_title" />

        <activity
            android:name=".ui.page.main.ba.BaPoolActivity"
            android:configChanges="keyboardHidden|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
            android:enableOnBackInvokedCallback="true"
            android:exported="false"
            android:label="@string/ba_pool_activity_title" />

        <activity
            android:name=".ui.page.main.debug.DebugComponentLabActivity"
            android:configChanges="keyboardHidden|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
            android:exported="false"
            android:label="@string/debug_component_lab_title" />

        <activity
            android:name=".ui.page.main.debug.DebugLiquidCatalogActivity"
            android:configChanges="keyboardHidden|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
            android:exported="false"
            android:label="@string/debug_component_lab_liquid_catalog_title" />

        <activity
            android:name=".ui.page.main.student.GuideVideoFullscreenActivity"
            android:configChanges="keyboardHidden|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
            android:enableOnBackInvokedCallback="true"
            android:excludeFromRecents="true"
            android:exported="false" />

        <activity
            android:name="com.yalantis.ucrop.UCropActivity"
            android:exported="false"
            android:screenOrientation="portrait"
            android:theme="@style/Theme.AppCompat.Light.NoActionBar" />

        <service
            android:name=".ui.page.main.student.BaGuideBgmMediaSessionService"
            android:enabled="true"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback">
            <intent-filter>
                <action android:name="androidx.media3.session.MediaSessionService" />
            </intent-filter>
        </service>

        <receiver
            android:name=".feature.notification.NotificationActionReceiver"
            android:enabled="true"
            android:exported="false" />

        <receiver
            android:name=".feature.notification.MiFocusNotificationActionReceiver"
            android:enabled="true"
            android:exported="true" />

        <receiver
            android:name=".feature.github.notification.GitHubShareImportActionReceiver"
            android:enabled="true"
            android:exported="true" />

        <receiver
            android:name=".feature.github.install.GitHubShizukuInstallResultReceiver"
            android:enabled="true"
            android:exported="false" />

        <receiver
            android:name=".core.shortcut.AppShortcutActionReceiver"
            android:enabled="true"
            android:exported="false" />

        <receiver
            android:name=".core.background.AppBackgroundTickReceiver"
            android:enabled="true"
            android:exported="false" />
    </application>

</manifest>
