<?xml version="1.0" encoding="utf-8"?>
<data-extraction-rules>
    <!-- Keep data migration explicit through WebDAV and JSON import/export surfaces. -->
    <cloud-backup>
        <exclude
            domain="root"
            path="." />
        <exclude
            domain="device_root"
            path="." />
    </cloud-backup>
    <device-transfer>
        <exclude
            domain="root"
            path="." />
        <exclude
            domain="device_root"
            path="." />
    </device-transfer>
</data-extraction-rules>
